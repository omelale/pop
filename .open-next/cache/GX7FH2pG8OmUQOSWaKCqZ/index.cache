ref=\"/_next/static/css/01f2adbe3fcf7ca8.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-5b800b0b79c06ee1.js\"/><script src=\"/_next/static/chunks/4bd1b696-c023c6e3521b1417.js\" async=\"\"></script><script src=\"/_next/static/chunks/255-e3bf15caf1f1e0f9.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-74ba9b29429761b7.js\" async=\"\"></script><script src=\"/_next/static/chunks/687-27224853e12c655e.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/page-55ae1f53818fd413.js\" async=\"\"></script><meta name=\"next-size-adjust\" content=\"\"/><title>POP — Place Of People · Coffee · Brunch · Cocktails</title><meta name=\"description\" content=\"POP is a fluid, all-day bistro in Tirana — coffee to brunch to cocktails, every moment shared between people. Opening soon.\"/><meta name=\"keywords\" content=\"POP,Place Of People,bistro,Tirana,coffee,brunch,cocktails,Albania\"/><meta property=\"og:title\" content=\"POP — Place Of People\"/><meta property=\"og:description\" content=\"One place, every part of the day. Coffee, brunch, cocktails — and every moment shared between.\"/><meta property=\"og:url\" content=\"https://popbistro.al\"/><meta property=\"og:site_name\" content=\"POP\"/><meta property=\"og:locale\" content=\"en_AL\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary\"/><meta name=\"twitter:title\" content=\"POP — Place Of People\"/><meta name=\"twitter:description\" content=\"One place, every part of the day. Coffee, brunch, cocktails — and every moment shared between.\"/><link rel=\"icon\" href=\"/favicon.svg\" type=\"image/svg+xml\"/><link rel=\"icon\" href=\"/logo.svg\" type=\"image/svg+xml\"/><script src=\"/_next/static/chunks/polyfills-42372ed130431b0a.js\" noModule=\"\"></script></head><body class=\"__variable_cf7633 __variable_0fc2d1\"><div hidden=\"\"><!--$--><!--/$--></div><div class=\"fixed inset-0 z-[100] flex items-center justify-center bg-terracotta\" aria-hidden=\"true\" style=\"opacity:1\"><div class=\"flex flex-col items-center gap-3\" style=\"opacity:0;transform:scale(0.92)\"><img src=\"/logo.png\" alt=\"POP — Place Of People\" class=\"h-16 w-auto object-contain\"/><span data-logo-fallback=\"true\" class=\"hidden items-center text-3xl font-black uppercase tracking-[0.25em] text-cream\" style=\"font-family:var(--font-display)\">POP</span><span class=\"mt-2 text-[10px] uppercase tracking-[0.5em] text-cream/70\" style=\"font-family:var(--font-body)\">Place Of People</span></div></div><header class=\"fixed inset-x-0 top-0 z-50 transition-colors duration-500 bg-transparent\" style=\"transform:translateY(-80px)\"><div class=\"container-pop flex h-20 items-center justify-between\"><a href=\"#home\" class=\"group flex items-center gap-3\"><span class=\"leading-none\"><svg viewBox=\"0 0 480 120\" xmlns=\"http://www.w3.org/2000/svg\" class=\"h-7 w-auto transition-all duration-300 md:h-9\" role=\"img\" aria-label=\"POP — Place Of People\"><text x=\"240\" y=\"86\" text-anchor=\"middle\" font-size=\"104\" font-family=\"&#x27;Fraunces&#x27;, Georgia, &#x27;Times New Roman&#x27;, serif\" font-style=\"normal\" font-weight=\"900\" letter-spacing=\"0.2em\" fill=\"#F4EEE1\" dominant-baseline=\"middle\">POP</text></svg></span><span class=\"hidden text-[10px] uppercase tracking-[0.4em] transition-colors duration-300 md:inline text-cream/85\" style=\"font-family:var(--font-body)\">Place Of People</span></a><nav class=\"hidden items-center gap-6 lg:gap-7 lg:flex\"><a href=\"#home\" class=\"link-underline text-[11px] uppercase tracking-[0.24em] transition-colors duration-300 md:text-xs text-cream hover:text-terracotta\">Home</a><a href=\"#menu\" class=\"link-underline text-[11px] uppercase tracking-[0.24em] transition-colors duration-300 md:text-xs text-cream hover:text-terracotta\">Menu</a><a href=\"#events\" class=\"link-underline text-[11px] uppercase tracking-[0.24em] transition-colors duration-300 md:text-xs text-cream hover:text-terracotta\">Events</a><a href=\"#gallery\" class=\"link-underline text-[11px] uppercase tracking-[0.24em] transition-colors duration-300 md:text-xs text-cream hover:text-terracotta\">Gallery</a><a href=\"#location\" class=\"link-underline text-[11px] uppercase tracking-[0.24em] transition-colors duration-300 md:text-xs text-cream hover:text-terracotta\">Location</a><a href=\"#about\" class=\"link-underline text-[11px] uppercase tracking-[0.24em] transition-colors duration-300 md:text-xs text-cream hover:text-terracotta\">About</a><a href=\"https://www.instagram.com/popbistro.al/\" target=\"_blank\" rel=\"noopener noreferrer\" aria-label=\"POP on Instagram\" class=\"transition-colors duration-300 text-cream hover:text-terracotta\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"1.6\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-instagram h-[18px] w-[18px]\"><rect width=\"20\" height=\"20\" x=\"2\" y=\"2\" rx=\"5\" ry=\"5\"></rect><path d=\"M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z\"></path><line x1=\"17.5\" x2=\"17.51\" y1=\"6.5\" y2=\"6.5\"></line></svg></a><a href=\"#location\" class=\"btn-primary\">Reserve a Table</a></nav><button type=\"button\" aria-label=\"Open menu\" aria-expanded=\"false\" class=\"lg:hidden transition-colors duration-300 text-cream\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-menu h-7 w-7\"><line x1=\"4\" x2=\"20\" y1=\"12\" y2=\"12\"></line><line x1=\"4\" x2=\"20\" y1=\"6\" y2=\"6\"></line><line x1=\"4\" x2=\"20\" y1=\"18\" y2=\"18\"></line></svg></button></div></header><main id=\"home\"><section id=\"home\" class=\"relative w-full overflow-hidden\" style=\"height:100vh\"><div class=\"absolute inset-0 -z-10\"><div class=\"absolute inset-0 bg-black/40\"></div><video class=\"absolute inset-0 h-full w-full object-cover transition-opacity duration-1000 opacity-0\" autoPlay=\"\" muted=\"\" loop=\"\" playsInline=\"\" poster=\"https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&amp;fit=crop&amp;w=1920&amp;q=80\" src=\"/hero.mp4\"></video><img src=\"https://images.unsplash.com/photo-1517248135467-4c7edcad34c4?auto=format&amp;fit=crop&amp;w=1920&amp;q=80\" alt=\"POP bistro atmosphere\" class=\"absolute inset-0 h-full w-full object-cover\"/><div class=\"pointer-events-none absolute inset-x-0 bottom-0 h-2/3\" style=\"background:linear-gradient(to top, rgba(193,80,59,0.85) 0%, rgba(193,80,59,0.35) 40%, transparent 100%)\"></div><div class=\"pointer-events-none absolute inset-0 bg-gradient-to-b from-black/30 via-transparent to-transparent\"></div></div><div class=\"container-pop relative flex h-full flex-col items-center justify-center text-center text-cream\"><div style=\"opacity:0;transform:scale(0.92)\"><svg viewBox=\"0 0 480 120\" xmlns=\"http://www.w3.org/2000/svg\" class=\"mx-auto mb-7 h-24 w-auto drop-shadow-md md:h-32\" role=\"img\" aria-label=\"POP — Place Of People\"><text x=\"240\" y=\"86\" text-anchor=\"middle\" font-size=\"104\" font-family=\"&#x27;Fraunces&#x27;, Georgia, &#x27;Times New Roman&#x27;, serif\" font-style=\"normal\" font-weight=\"900\" letter-spacing=\"0.2em\" fill=\"#F4EEE1\" dominant-baseline=\"middle\">POP</text></svg></div><p class=\"mb-6 text-[11px] uppercase tracking-[0.6em] text-cream/90 md:text-xs\" style=\"opacity:0;transform:translateY(14px)\">PLACE OF PEOPLE</p><h1 class=\"heading-display hero-motto text-balance text-4xl leading-[1.08] text-cream md:text-6xl lg:text-7xl\"><span class=\"block normal-case\" style=\"opacity:0;transform:translateY(36px)\">Every place has a name.</span><span class=\"mt-2 block font-semibold italic normal-case\" style=\"opacity:0;transform:translateY(36px)\">Ours has a feeling.</span></h1><a href=\"#intro\" class=\"absolute bottom-10 flex flex-col items-center gap-2 text-cream/80\" aria-label=\"Scroll down\" style=\"opacity:0\"><span class=\"text-[10px] uppercase tracking-[0.3em]\">Scroll to discover</span><span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-chevron-down h-5 w-5\"><path d=\"m6 9 6 6 6-6\"></path></svg></span></a></div></section><section id=\"intro\" class=\"relative overflow-hidden bg-cream py-24 md:py-32\"><div class=\"container-pop grid grid-cols-1 items-center gap-12 md:grid-cols-2 md:gap-16 lg:gap-24\"><div class=\"relative aspect-[4/5] overflow-hidden\" style=\"opacity:0;transform:scale(1.06)\"><img src=\"https://images.unsplash.com/photo-1529333166437-7750a6dd5a70?auto=format&amp;fit=crop&amp;w=1000&amp;q=80\" alt=\"People gathered, laughing and sharing a meal at POP\" class=\"h-full w-full object-cover\"/><div class=\"pointer-events-none absolute inset-0 bg-gradient-to-tr from-terracotta/15 via-transparent to-transparent\"></div></div><div class=\"flex flex-col justify-center text-ink\"><span class=\"eyebrow\" style=\"opacity:0;transform:translateY(20px)\">COFFEE. BRUNCH. COCKTAILS.</span><h2 class=\"heading-display mb-6 text-3xl text-balance md:text-5xl\" style=\"opacity:0;transform:translateY(30px)\">One place, every part of the day</h2><p class=\"mb-8 max-w-md text-base leading-relaxed text-ink/75 md:text-lg\" style=\"opacity:0;transform:translateY(30px)\">Welcome to POP, a place where mornings begin with coffee, afternoons turn into brunch, evenings end with cocktails, and every moment is shared with people.</p><a href=\"#about\" class=\"group inline-flex items-center gap-2 text-sm uppercase tracking-[0.18em] text-terracotta\" style=\"opacity:0;transform:translateY(16px)\"><span class=\"link-underline\">explore more</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right h-4 w-4 transition-transform duration-300 group-hover:translate-x-1\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div><span class=\"eyebrow absolute bottom-6 right-8 hidden uppercase tracking-[0.6em] opacity-20 md:block\" style=\"opacity:0\">POP — PLACE OF PEOPLE</span></section><section class=\"relative overflow-hidden bg-ink text-cream\"><div class=\"container-pop grid grid-cols-1 items-center gap-10 py-20 md:grid-cols-2 md:gap-16 md:py-28 lg:gap-24\"><div class=\" relative aspect-[5/6] overflow-hidden\" style=\"opacity:0;transform:scale(1.08)\"><img src=\"https://images.unsplash.com/photo-1495474472287-4d71bcdd2085?auto=format&amp;fit=crop&amp;w=1200&amp;q=80\" alt=\"Barista pouring coffee art\" class=\"h-full w-full object-cover\"/></div><div class=\" flex flex-col\"><span class=\"eyebrow !text-terracotta\" style=\"opacity:0;transform:translateY(20px)\">MENU</span><h2 class=\"heading-display mb-5 text-3xl text-balance md:text-5xl\" style=\"opacity:0;transform:translateY(30px)\">Made to linger over</h2><p class=\"mb-8 max-w-md text-base leading-relaxed md:text-lg text-cream/80\" style=\"opacity:0;transform:translateY(30px)\">Our menu flows the way a good day does — from first coffee and fresh pastries through long, sunlit brunches to golden-hour cocktails. Simple things, done exceptionally, whenever you need them.</p><a href=\"#menu\" class=\"group inline-flex items-center gap-2 text-sm uppercase tracking-[0.18em] text-cream\" style=\"opacity:0;transform:translateY(16px)\"><span class=\"link-underline\">View Full Menu</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right h-4 w-4 transition-transform duration-300 group-hover:translate-x-1\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div></section><section class=\"relative overflow-hidden bg-cream\"><div class=\"container-pop grid grid-cols-1 items-center gap-10 py-20 md:grid-cols-2 md:gap-16 md:py-28 lg:gap-24\"><div class=\"md:order-2 relative aspect-[5/6] overflow-hidden\" style=\"opacity:0;transform:scale(1.08)\"><img src=\"https://images.unsplash.com/photo-1559329007-40df8a9345d8?auto=format&amp;fit=crop&amp;w=1200&amp;q=80\" alt=\"Cozy bistro interior\" class=\"h-full w-full object-cover\"/></div><div class=\"md:order-1 flex flex-col\"><span class=\"eyebrow \" style=\"opacity:0;transform:translateY(20px)\">THE SPACE</span><h2 class=\"heading-display mb-5 text-3xl text-balance md:text-5xl\" style=\"opacity:0;transform:translateY(30px)\">A room built for connection</h2><p class=\"mb-8 max-w-md text-base leading-relaxed md:text-lg text-ink/75\" style=\"opacity:0;transform:translateY(30px)\">Warm light, worn wood, and nooks that invite you to stay. POP was designed for the conversations that happen when you&#x27;re not watching the clock — a room that feels like it was built around your table.</p><a href=\"#gallery\" class=\"group inline-flex items-center gap-2 text-sm uppercase tracking-[0.18em] text-terracotta\" style=\"opacity:0;transform:translateY(16px)\"><span class=\"link-underline\">Explore Gallery</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right h-4 w-4 transition-transform duration-300 group-hover:translate-x-1\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div></section><section id=\"card-grid\" class=\"relative bg-cream py-24 md:py-32\"><div class=\"container-pop\"><div class=\"mb-12 flex flex-col items-center text-center md:mb-16\"><span class=\"eyebrow\">WAYS IN</span><h2 class=\"heading-display max-w-2xl text-balance text-3xl md:text-5xl\">Find your way into POP</h2></div><div class=\"grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4\"><a href=\"#events\" class=\"group relative block h-[420px] overflow-hidden sm:h-[460px]\"><img src=\"https://images.unsplash.com/photo-1530103862676-de8c9debad1d?auto=format&amp;fit=crop&amp;w=900&amp;q=80\" alt=\"Friends celebrating together\" class=\"absolute inset-0 h-full w-full object-cover\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent transition-colors duration-500 group-hover:from-terracotta/80 group-hover:via-black/30 group-hover:to-transparent\"></div><div class=\"relative flex h-full flex-col justify-end p-8 text-cream\"><span class=\"mb-2 text-[10px] uppercase tracking-[0.4em]\">GATHER</span><h3 class=\"heading-display mb-4 max-w-[14rem] text-2xl leading-tight text-balance\">Ways to gather beyond the table</h3><span class=\"inline-flex items-center gap-2 text-xs uppercase tracking-[0.22em]\"><span class=\"link-underline\">explore more</span><span class=\"inline-block\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-up-right h-4 w-4\"><path d=\"M7 7h10v10\"></path><path d=\"M7 17 17 7\"></path></svg></span></span></div></a><a href=\"#gallery\" class=\"group relative block h-[420px] overflow-hidden sm:h-[460px]\"><img src=\"https://images.unsplash.com/photo-1554118811-1e0d58224f24?auto=format&amp;fit=crop&amp;w=900&amp;q=80\" alt=\"Bar atmosphere\" class=\"absolute inset-0 h-full w-full object-cover\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent transition-colors duration-500 group-hover:from-terracotta/80 group-hover:via-black/30 group-hover:to-transparent\"></div><div class=\"relative flex h-full flex-col justify-end p-8 text-cream\"><span class=\"mb-2 text-[10px] uppercase tracking-[0.4em]\">CAPTURE</span><h3 class=\"heading-display mb-4 max-w-[14rem] text-2xl leading-tight text-balance\">Moments, captured as they happen</h3><span class=\"inline-flex items-center gap-2 text-xs uppercase tracking-[0.22em]\"><span class=\"link-underline\">explore more</span><span class=\"inline-block\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-up-right h-4 w-4\"><path d=\"M7 7h10v10\"></path><path d=\"M7 17 17 7\"></path></svg></span></span></div></a><a href=\"#community\" class=\"group relative block h-[420px] overflow-hidden sm:h-[460px]\"><img src=\"https://images.unsplash.com/photo-1517457373958-b7bdd4587205?auto=format&amp;fit=crop&amp;w=900&amp;q=80\" alt=\"People toastimg with drinks\" class=\"absolute inset-0 h-full w-full object-cover\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent transition-colors duration-500 group-hover:from-terracotta/80 group-hover:via-black/30 group-hover:to-transparent\"></div><div class=\"relative flex h-full flex-col justify-end p-8 text-cream\"><span class=\"mb-2 text-[10px] uppercase tracking-[0.4em]\">BELONG</span><h3 class=\"heading-display mb-4 max-w-[14rem] text-2xl leading-tight text-balance\">Where regulars become family</h3><span class=\"inline-flex items-center gap-2 text-xs uppercase tracking-[0.22em]\"><span class=\"link-underline\">explore more</span><span class=\"inline-block\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-up-right h-4 w-4\"><path d=\"M7 7h10v10\"></path><path d=\"M7 17 17 7\"></path></svg></span></span></div></a><a href=\"#menu\" class=\"group relative block h-[420px] overflow-hidden sm:h-[460px]\"><img src=\"https://images.unsplash.com/photo-1514362545857-3bc16c4c7d1b?auto=format&amp;fit=crop&amp;w=900&amp;q=80\" alt=\"Cocktail being prepared\" class=\"absolute inset-0 h-full w-full object-cover\"/><div class=\"absolute inset-0 bg-gradient-to-t from-black/70 via-black/25 to-transparent transition-colors duration-500 group-hover:from-terracotta/80 group-hover:via-black/30 group-hover:to-transparent\"></div><div class=\"relative flex h-full flex-col justify-end p-8 text-cream\"><span class=\"mb-2 text-[10px] uppercase tracking-[0.4em]\">TASTE</span><h3 class=\"heading-display mb-4 max-w-[14rem] text-2xl leading-tight text-balance\">Coffee to cocktails, all day</h3><span class=\"inline-flex items-center gap-2 text-xs uppercase tracking-[0.22em]\"><span class=\"link-underline\">explore more</span><span class=\"inline-block\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-up-right h-4 w-4\"><path d=\"M7 7h10v10\"></path><path d=\"M7 17 17 7\"></path></svg></span></span></div></a></div></div></section><section id=\"about\" class=\"relative overflow-hidden bg-terracotta py-24 md:py-32\"><div class=\"absolute inset-0 -z-0\"><img src=\"https://images.unsplash.com/photo-1414235077428-338989a2e8c0?auto=format&amp;fit=crop&amp;w=1920&amp;q=80\" alt=\"\" class=\"h-full w-full object-cover\"/><div class=\"absolute inset-0 bg-terracotta/90\"></div><div class=\"absolute inset-0 bg-gradient-to-br from-terracotta/95 via-transparent to-terracotta/80\"></div></div><div class=\"container-pop relative grid grid-cols-1 items-center gap-16 md:grid-cols-2\"><div class=\"flex flex-col items-start\" style=\"opacity:0;transform:translateY(30px)\"><svg viewBox=\"0 0 480 120\" xmlns=\"http://www.w3.org/2000/svg\" class=\"mb-6 h-20 w-auto drop-shadow-sm\" role=\"img\" aria-label=\"POP — Place Of People\"><text x=\"240\" y=\"86\" text-anchor=\"middle\" font-size=\"104\" font-family=\"&#x27;Fraunces&#x27;, Georgia, &#x27;Times New Roman&#x27;, serif\" font-style=\"normal\" font-weight=\"900\" letter-spacing=\"0.2em\" fill=\"#F4EEE1\" dominant-baseline=\"middle\">POP</text></svg><span class=\"mt-2 inline-flex w-fit items-center gap-2 rounded-full border border-cream/40 px-4 py-1.5 text-[11px] uppercase tracking-[0.4em] text-cream/90\"><span class=\"h-1.5 w-1.5 rounded-full bg-cream\"></span>Opening soon</span></div><div class=\"text-cream\"><span class=\"eyebrow !text-cream\" style=\"opacity:0;transform:translateY(20px)\">ABOUT</span><h2 class=\"heading-display mb-6 text-3xl text-balance md:text-5xl\" style=\"opacity:0;transform:translateY(30px)\">A place of people, opening soon</h2><p class=\"mb-10 max-w-md text-base leading-relaxed text-cream/85 md:text-lg\" style=\"opacity:0;transform:translateY(30px)\">POP was born from a simple idea: that the best moments in the day aren&#x27;t defined by the food or the drink, but by who you share them with. Coffee starts the conversation. Brunch lingers in it. Cocktails close it out. Everything in between is the point.</p><a href=\"#\" class=\"group inline-flex items-center gap-2 text-sm uppercase tracking-[0.18em] text-cream\" style=\"opacity:0;transform:translateY(16px)\"><span class=\"link-underline\">Our full story</span><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right h-4 w-4 transition-transform duration-300 group-hover:translate-x-1\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></a></div></div><div class=\"absolute -bottom-1 left-0 right-0 h-px bg-cream/30\" style=\"transform-origin:left;transform:scaleX(0)\"></div></section><section id=\"location\" class=\"relative overflow-hidden bg-cream\"><div class=\"grid grid-cols-1 md:grid-cols-2\"><div class=\"container-pop py-24 md:py-32\"><span class=\"eyebrow\" style=\"opacity:0;transform:translateY(20px)\">VISIT US</span><h2 class=\"heading-display mb-10 max-w-md text-3xl text-balance md:text-5xl\" style=\"opacity:0;transform:translateY(30px)\">Find us when you need us</h2><ul class=\"space-y-6 text-ink\"><li class=\"flex items-start gap-4\" style=\"opacity:0;transform:translateX(-20px)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-map-pin mt-1 h-5 w-5 flex-none text-terracotta\"><path d=\"M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0\"></path><circle cx=\"12\" cy=\"10\" r=\"3\"></circle></svg><span class=\"leading-relaxed\">Coming to a neighbourhood near you — Tirana, Albania</span></li><li class=\"flex items-start gap-4\" style=\"opacity:0;transform:translateX(-20px)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-phone mt-1 h-5 w-5 flex-none text-terracotta\"><path d=\"M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z\"></path></svg><a href=\"tel:+355000000000\" class=\"link-underline\">+355 00 000 0000</a></li><li class=\"flex items-start gap-4\" style=\"opacity:0;transform:translateX(-20px)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-mail mt-1 h-5 w-5 flex-none text-terracotta\"><rect width=\"20\" height=\"16\" x=\"2\" y=\"4\" rx=\"2\"></rect><path d=\"m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7\"></path></svg><a href=\"mailto:hello@popbistro.al\" class=\"link-underline\">hello@popbistro.al</a></li><li class=\"flex items-start gap-4\" style=\"opacity:0;transform:translateX(-20px)\"><svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-clock mt-1 h-5 w-5 flex-none text-terracotta\"><circle cx=\"12\" cy=\"12\" r=\"10\"></circle><polyline points=\"12 6 12 12 16 14\"></polyline></svg><div><div class=\"font-medium\">Monday – Sunday</div><div class=\"text-ink/70\">Coffee from 7 AM   ·   Cocktails until late</div></div></li></ul><div class=\"mt-12 border-t border-ink/15 pt-10\" style=\"opacity:0;transform:translateY(20px)\"><form><h3 class=\"heading-display mb-2 text-xl md:text-2xl\">Be the first to know when we open</h3><div class=\"mt-5 flex w-full max-w-md flex-col gap-3 sm:flex-row\"><input type=\"email\" required=\"\" placeholder=\"your@email.com\" class=\"flex-1 border-b border-ink/30 bg-transparent px-1 py-3 text-ink placeholder:text-ink/40 focus:border-terracotta focus:outline-none\" aria-label=\"Email address\" value=\"\"/><button type=\"submit\" class=\"btn-primary\">Notify me<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\" class=\"lucide lucide-arrow-right ml-2 h-4 w-4\"><path d=\"M5 12h14\"></path><path d=\"m12 5 7 7-7 7\"></path></svg></button></div></form></div></div><div class=\"relative min-h-[420px] md: